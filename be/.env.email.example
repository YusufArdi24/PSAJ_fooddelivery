# Email Configuration untuk Gmail SMTP
# Tambahkan konfigurasi ini ke file .env Anda

# ========================================
# EMAIL VERIFICATION SETUP
# ========================================

# Basic Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-gmail@gmail.com"
MAIL_FROM_NAME="Warung Edin"

# Application Configuration
APP_URL=http://localhost:8000

# ========================================
# CARA SETUP GMAIL SMTP:
# ========================================

# 1. Buka Gmail → Pengaturan → Keamanan
# 2. Aktifkan "Verifikasi 2 Langkah" 
# 3. Buat "App Password" untuk Laravel
# 4. Gunakan App Password di MAIL_PASSWORD (bukan password Gmail asli)
# 5. Ganti your-gmail@gmail.com dengan email Anda
# 6. Ganti your-app-password dengan App Password yang dibuat

# ========================================
# TESTING EMAIL:
# ========================================
# Jalankan command berikut untuk test:
# php artisan tinker
# 
# Kemudian ketik:
# \App\Models\Customer::first()->sendEmailVerificationNotification();
# 
# atau
# 
# \App\Models\Admin::first()->sendEmailVerificationNotification();