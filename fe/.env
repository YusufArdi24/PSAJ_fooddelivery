# Maps Configuration
# Using OpenStreetMap with Leaflet - FREE and no API key required!
# No billing needed, no credit card required

# Google OAuth Client ID
# Dapatkan dari: https://console.cloud.google.com/
# Lihat panduan di GOOGLE_LOGIN_SETUP.md
VITE_GOOGLE_CLIENT_ID=1005384546839-dc85a0v3fb1o6etlhe5rakivsfbc795a.apps.googleusercontent.com

# API Base URL - untuk development gunakan backend lokal
# Development: http://localhost:5000/api/v1 (jika backend jalan di port 5000)
# Production: https://psajfooddelivery-production.up.railway.app/api/v1
VITE_API_BASE_URL=http://localhost:5000/api/v1
